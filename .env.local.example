# Copia este archivo a .env.local y rellena con tus credenciales de Supabase.
# .env.local NO se sube a git (está en .gitignore).
#
# Donde encontrarlas:
# 1. Ve a https://supabase.com/dashboard/project/_/settings/api
# 2. Project URL → NEXT_PUBLIC_SUPABASE_URL
# 3. anon public key → NEXT_PUBLIC_SUPABASE_ANON_KEY
# 4. service_role key (secret) → SUPABASE_SERVICE_ROLE_KEY (¡no la expongas al cliente!)

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# URL pública del app (para metadata, callbacks de auth, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
